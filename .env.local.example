# ─── Database (Neon) ──────────────────────────────────────────────────────────
# Pooled connection (use this for most queries)
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/neondb?channel_binding=require&sslmode=require
# Unpooled connection (needed for migrations)
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/neondb?sslmode=require

PGHOST=HOST-pooler.region.aws.neon.tech
PGHOST_UNPOOLED=HOST.region.aws.neon.tech
PGUSER=neondb_owner
PGDATABASE=neondb
PGPASSWORD=YOUR_NEON_PASSWORD

POSTGRES_URL=postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/neondb?channel_binding=require&sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/neondb?channel_binding=require&sslmode=require
POSTGRES_USER=neondb_owner
POSTGRES_HOST=HOST-pooler.region.aws.neon.tech
POSTGRES_PASSWORD=YOUR_NEON_PASSWORD
POSTGRES_DATABASE=neondb
POSTGRES_URL_NO_SSL=postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/neondb
POSTGRES_PRISMA_URL=postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/neondb?channel_binding=require&connect_timeout=15&sslmode=require

# ─── Auth (NextAuth) ──────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-super-secret-key-here-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# ─── Admin credentials ────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@mbfarmhouse.co.za
ADMIN_PASSWORD=your-secure-admin-password

# ─── PayFast Payment Gateway ──────────────────────────────────────────────────
PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
PAYFAST_PASSPHRASE=your-passphrase
# Sandbox: https://sandbox.payfast.co.za/eng/process
# Production: https://www.payfast.co.za/eng/process
NEXT_PUBLIC_PAYFAST_URL=https://sandbox.payfast.co.za/eng/process

# ─── Public site config ───────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_PHONE=+92 370 7165804
