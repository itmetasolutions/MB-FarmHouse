NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/mb_farmhouse_official/

# ─── Migration endpoint protection ───────────────────────────────────────────
MIGRATION_SECRET=a-random-secret-to-protect-the-migrate-endpoint
